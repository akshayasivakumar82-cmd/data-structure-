class Solution:
    def longestConsecutive(self, arr):
        s = set(arr)
        max_len = 0

        for num in arr:
            if num - 1 not in s:  # start of a sequence
                current = num
                length = 1

                while current + 1 in s:
                    current += 1
                    length += 1

                max_len = max(max_len, length)

        return max_len
