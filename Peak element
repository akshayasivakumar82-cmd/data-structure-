class Solution:
    def peakElement(self, arr):
        n = len(arr)
        left = 0
        right = n - 1

        while left <= right:
            mid = (left + right) // 2

            if (mid == 0 or arr[mid] > arr[mid-1]) and (mid == n-1 or arr[mid] > arr[mid+1]):
                return mid
            elif mid > 0 and arr[mid-1] > arr[mid]:
                right = mid - 1
            else:
                left = mid + 1
        
