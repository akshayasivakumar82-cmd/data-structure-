class Solution:
    def majorityElement(self, arr):
        count = 0
        candidate = None

        # Find candidate
        for num in arr:
            if count == 0:
                candidate = num
            if num == candidate:
                count += 1
            else:
                count -= 1

        # Verify candidate
        if arr.count(candidate) > len(arr) // 2:
            return candidate
        else:
            return -1
